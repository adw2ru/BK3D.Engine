START:	MTPS #200

	MOV #1,@#PpuComm

	MOV #PPUBEG,R4
	MOV #PPUEND-PPUBEG/2,R5
	CALL PPRUN
	TST @#PpuComm
	BNE .-4

	CLR BITFLD
	CLR AMAP
	CALL CLWHLE
	MOV @#100,(PC)+
OLDTMI:	.WORD 0
	MOV @#102,(PC)+
OLDTMM:	.WORD 0
	MOV #NEWTMI,@#100
	MOV #200,@#102
	MOV #F_TMR,R0
	CALL SCH2
	TST @#PpuComm
	BNE .-4
	MTPS #0
	JMP GOTIT
NEWTMI:	BIT BITFLD,#8.
	BEQ 1$
	BIT SKIP,#1
	BNE 1$
	MOV R0,-(SP)
	MOV R1,-(SP)
	MOV R2,-(SP)
	MOV R3,-(SP)
	MOV R4,-(SP)
	MOV R5,-(SP)
	MOV @#176640,-(SP)
	CALL GLOGIC
	MOV (SP)+,@#176640
	MOV (SP)+,R5
	MOV (SP)+,R4
	MOV (SP)+,R3
	MOV (SP)+,R2
	MOV (SP)+,R1
	MOV (SP)+,R0
1$:	INC (PC)+
SKIP:	.WORD 0
	CMP SKIP,#50.
	BLO 2$
	CLR SKIP
	BIS #128.,BITFLD
2$:	RTI
SCH2:	MFPS -(SP)
	MTPS #200
	TST @#PpuComm
	BNE .-4
	MOV #1,@#PpuComm
	BIT #128.,@#176674
	BEQ .-6
	MOVB R0,@#176676
	BIT #128.,@#176674
	BEQ .-6
	MTPS (SP)+
	RET
CLWHLE:	MOV #40000,R0
	MOV #15440.,R3
	CLR (R0)+
	SOB R3,.-2
CLVRAM:	MOV #100000,@#176640
	MOV #20480.,R3
1$:	CLR @#176642
	INC @#176640
	SOB R3,1$
	RET
