STRNP:	.WORD 23.,12.
STRN:	.ASCII<0><0>
	.EVEN
STRPL:	.WORD 16.,16.
STRPP1:	.ASCII"GRB"<0>
STRPP2:	.ASCII"RGB"<0>
STRPP3:	.ASCII"BW1"<0>
STRPP4:	.ASCII"BW2"<0>
	.EVEN
