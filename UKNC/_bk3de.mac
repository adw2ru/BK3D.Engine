	RET
SETPL:	MOV R0,PLX
	MOV R1,PLY
	RET
GETDIR:	MOV PLA,R0
	CALL GSNCS
	RET
DDWN:	CALL GETDIR
DDWN2:	NEG R0
	NEG R1
	BR DUP2
DUP:	CALL GETDIR
DUP2:	MOV R0,R2
	MOV R1,R3
	ADD PLX,R0
	ADD PLY,R1
	CALL CHECK
	BNE 1$
	CALL SETPL
	BR 3$
