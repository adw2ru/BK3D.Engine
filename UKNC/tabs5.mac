CALCD:	; CALC DIVS (FOR BIG WALLS DRAW	CODE)
	MOV #DIVS,R0
	MOV #224.,R5	; 32..256
1$:	MOV #16.,R2
	SWAB R2
	MOV #257.,R4
	SUB R5,R4
	CALL SPDIV
	MOVB R2,(R0)+
	SOB R5,1$
	;
	; WRC TABLES (FOR SMALL	WALLS DRAW CODE)
	MOV #WRC+64.,R0
	MOV R0,R3
	MOV #32.,R5
100$:	MOV R3,-(R0)
	MOV R0,-(SP)
	MOV R3,-(SP)
	MOV #4096.,R2	; 16.*256.
	MOV R5,R4	; /R5
	CALL SPDIV
	MOV (SP)+,R3
	MOV R5,R4
	CLR R0
101$:	MOV R0,R1
	SWAB R1
	ASLB R1
	MOVB R1,(R3)+
	ADD R2,R0
	SOB R4,101$
	MOV (SP)+,R0
	SOB R5,100$
	;
	MOV #FRBF2+1,R0
	MOV #64.,R1
102$:	MOVB #32.,(R0)
	ADD #2,R0
	SOB R1,102$
	;
	MOV #TXTDAT,R0
	MOV #TXTH1,R1
	MOV #1024.,R2	; 4*16*16
103$:	MOVB (R0)+,R3
	ASL R3
	MOV MTRLV(R3),R4
	MOV (R4),2048.(R1)
	MOV MTRLH(R3),R4
	MOV (R4),(R1)+
	SOB R2,103$
	;
	RET
	;
MTRLH:	.WORD MCLR1+0.
	.WORD MCLR1+6.,MCLR1+4.,MCLR1+2.,MCLR1+8.
