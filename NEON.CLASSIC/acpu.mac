	@include fnt35.mac
	@include cmn35.mac	
	@include ar35.mac
	@include s35.mac
	@include tabs35.mac
	@include util35.mac
	@include wl35.mac
	@include mn35.mac
	@include lg35.mac
	@include txt35.mac
	@include menu35.mac
	.even

CpuEnd:

